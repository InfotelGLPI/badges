{% if rows is not empty %}
<table class="tab_cadre_fixe badges_wizard_info">
    {% for row in rows %}
    <tr>
        <td><b>{{ __('Visitor firstname', 'badges') }}</b></td>
        <td>{{ row.visitor_firstname }}</td>
        <td><b>{{ __('Visitor realname', 'badges') }}</b></td>
        <td>{{ row.visitor_realname }}</td>
    </tr>
    <tr>
        <td><b>{{ __('Visitor society', 'badges') }}</b></td>
        <td>{{ row.visitor_society }}</td>
        <td><b>{{ __('Arrival date', 'badges') }}</b></td>
        <td>{{ row.affectation_date }}</td>
    </tr>
    {% endfor %}
</table>
{% endif %}
