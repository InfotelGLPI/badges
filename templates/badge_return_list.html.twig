<div class="center">
    <table class="tab_cadre_fixe">
        <tr>
            <th colspan="6">{{ __('Badge requests history', 'badges') }}</th>
        </tr>
        {% if rows is not empty %}
        <tr>
            <th>{{ __('Requester') }}</th>
            <th>{{ __('Visitor realname', 'badges') }}</th>
            <th>{{ __('Visitor firstname', 'badges') }}</th>
            <th>{{ __('Visitor society', 'badges') }}</th>
            <th>{{ __('Arrival date', 'badges') }}</th>
            <th>{{ __('Return date', 'badges') }}</th>
        </tr>
        {% for row in rows %}
        <tr class="tab_bg_1">
            <td>{{ row.requester_name|raw }}</td>
            <td>{{ row.visitor_realname }}</td>
            <td>{{ row.visitor_firstname }}</td>
            <td>{{ row.visitor_society }}</td>
            <td>{{ row.affectation_date }}</td>
            <td>{{ row.return_date }}</td>
        </tr>
        {% endfor %}
        {% else %}
        <tr>
            <td class="center" colspan="6">{{ __('No results found') }}</td>
        </tr>
        {% endif %}
    </table>
</div>
