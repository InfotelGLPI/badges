{% if canedit %}
<form name="form" method="post" action="{{ form_url }}" id="badges_formSearchBadges">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
    <div class="center">
        <table class="tab_cadre_fixe">
            <tr>
                <th colspan="6">{{ __('Badges usage search', 'badges') }}</th>
            </tr>
            <tr class="tab_bg_1">
                <td>{{ __('Arrival date', 'badges') }}</td>
                <td>{{ begin_date_field|raw }}</td>
                <td>{{ __('Return date', 'badges') }}</td>
                <td>{{ end_date_field|raw }}</td>
                <td>
                    <input type="button" class="submit btn btn-primary" name="addToCart"
                           value="{{ __('Search') }}"
                           onclick="badges_searchBadges('searchBadges','badges_formSearchBadges', 'badges_searchBadges');">
                    <input type="hidden" name="requesters_id" value="{{ requesters_id }}">
                </td>
            </tr>
        </table>
    </div>
    <script>$(document).ready(function() {badges_initJs("{{ web_dir|e('js') }}");});</script>
</form>
{% endif %}

<div class="center" id="badges_searchBadges">
    {{ initial_results|raw }}
</div>
<div id="dialog-confirm"></div>
